# ─────────────────────────────────────────────────────────────────
# Copiar a .env y rellenar antes de levantar los contenedores
# NUNCA subir .env al repositorio
# ─────────────────────────────────────────────────────────────────

# PostgreSQL
POSTGRES_DB=biomasa
POSTGRES_USER=biomasa_user
POSTGRES_PASSWORD=CAMBIA_ESTO_POR_CLAVE_SEGURA

# JWT — genera con: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=CAMBIA_ESTO_POR_SECRET_ALEATORIO_64_BYTES

# MinIO
MINIO_ROOT_USER=biomasa_minio
MINIO_ROOT_PASSWORD=CAMBIA_ESTO_POR_CLAVE_SEGURA

# SMTP — smtp.serviciodecorreo.es puerto 465 SSL/TLS
SMTP_HOST=smtp.serviciodecorreo.es
SMTP_PORT=465
SMTP_USER=biomasa@cserintranet.com
SMTP_PASS=RELLENAR_CON_CONTRASEÑA
SMTP_FROM="Albaranes Biomasa <biomasa@cserintranet.com>"
